# =========================================================================
# Comeet Frontend - Environment Configuration Template
# 이 파일을 `.env` 또는 `.env.local`로 복사하여 로컬 및 빌드 환경 변수를 설정하세요.
# =========================================================================

# 1. API & Backend Servers
# 백엔드 서버 API 베이스 URL (예: http://localhost:8080 또는 배포서버 주소)
VITE_API_BASE_URL=http://localhost:8080

# 백엔드 실시간 소켓 웹소켓 URL (예: ws://localhost:8080 또는 배포서버 주소)
VITE_WS_BASE_URL=ws://localhost:8080

# 2. Maps & External OAuth APIs
# 네이버 클라우드 플랫폼에서 발급받은 지도 Web Dynamic Map Client ID (index.html에서 로드)
VITE_NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here

# 카카오 REST API 인증용 REST API KEY (선택)
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 3. Application Metadata
# 브라우저 타이틀 및 헤더 기본 표시 값
VITE_APP_TITLE=Comeet

# 빌드 및 배포할 앱 버전
VITE_APP_VERSION=1.0.0

# 4. Feature Flags / Development Tools
# 디버그 개발 모드 로그 활성화 여부 (true | false)
VITE_ENABLE_DEBUG=true
